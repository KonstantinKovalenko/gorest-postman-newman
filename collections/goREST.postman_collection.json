              "script": {
                "type": "text/javascript",
                "exec": [
                  "const jsonResponse = pm.response.json()",
                  "",
                  "pm.variables.set(\"runtime_userId\", jsonResponse.id)",
                  "",
                  "pm.test(\"Created user name matches request\", () => {",
                  "    pm.expect(jsonResponse.name).to.equal(pm.variables.get(\"runtime_userName\"))",
                  "})",
                  "",
                  "pm.test(\"Created user email matches request\", () => {",
                  "    pm.expect(jsonResponse.email).to.equal(pm.variables.get(\"runtime_userEmail\"))",
                  "})",
                  "",
                  "pm.test(\"Created user gender matches request\", () => {",
                  "    pm.expect(jsonResponse.gender).to.equal(pm.variables.get(\"runtime_userGenderMale\"))",
                  "})",
                  "",
                  "pm.test(\"Created user status matches request\", () => {",
                  "    pm.expect(jsonResponse.status).to.equal(pm.variables.get(\"runtime_userStatusActive\"))",
                  "})"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"{{runtime_userName}}\",\n    \"gender\": \"{{runtime_userGenderMale}}\",\n    \"email\": \"{{runtime_userEmail}}\",\n    \"status\": \"{{runtime_userStatusActive}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{cfg_baseURL}}/users",
              "host": [
                "{{cfg_baseURL}}"
              ],
              "path": [
                "users"
              ]
            }
