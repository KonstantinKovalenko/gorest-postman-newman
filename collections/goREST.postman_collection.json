{
  "info": {
    "name": "GoRest API Testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{cfg_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if(!pm.variables.get(\"runtime_userId\")){",
          "    const currentDate = Date.now()",
          "    const random = Math.floor(Math.random() * 100)",
          "",
          "    pm.variables.set(\"runtime_expectedStatusCode\", 200)",
          "    ",
          "    pm.variables.set(\"runtime_userGenderMale\", \"male\")",
          "    pm.variables.set(\"runtime_userGenderFemale\", \"female\")",
          "    pm.variables.set(\"runtime_userStatusActive\", \"active\")",
          "    pm.variables.set(\"runtime_userStatusInactive\", \"inactive\")",
          "  ",
          "    pm.variables.set(\"runtime_userName\", `user_${currentDate}`)",
          "    pm.variables.set(\"runtime_userNameUpdated\", `user_${currentDate}${random}`)",
          "    pm.variables.set(\"runtime_userEmail\", `email_${currentDate}@qa.com`)",
          "    pm.variables.set(\"runtime_userEmailUpdated\", `email_${currentDate}${random}@qa.com`)",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const Ajv = require(\"ajv\")",
          "const ajv = new Ajv()",
          "",
          "const userSchemaRequests = [",
          "    \"201: Create User\",",
          "    \"200: Get User by ID\",",
          "    \"200: Update User\",",
          "    \"200: Partial Update User\"",
          "]",
          "",
          "const usersArraySchemaRequests = [",
          "    \"200: Get All Users\"",
          "]",
          "",
          "const contentTypeRequests = [",
          "    \"201: Create User\",",
          "    \"200: Get User by ID\",",
          "    \"200: Update User\",",
          "    \"200: Partial Update User\",",
          "    \"422: Create User with Existing Email\",",
          "    \"422: Update User with Invalid Gender\",",
          "    \"401: Partial Update User without Authorization\",",
          "    \"404: Get Deleted User by ID\",",
          "    \"200: Get All Users\"",
          "]",
          "",
          "const userSchema = {",
          "    type: \"object\",",
          "    required: [",
          "        \"id\",",
          "        \"name\",",
          "        \"email\",",
          "        \"gender\",",
          "        \"status\"",
          "    ],",
          "    properties: {",
          "        id: { type: \"integer\" },",
          "        name: { type: \"string\" },",
          "        email: { type: \"string\" },",
          "        gender: {",
          "            type: \"string\",",
          "            enum: [\"male\", \"female\"]",
          "        },",
          "        status: {",
          "            type: \"string\",",
          "            enum: [\"active\", \"inactive\"]",
          "        }",
          "    }",
          "}",
          "",
          "const userArraySchema = {",
          "    type: \"array\",",
          "    items: userSchema",
          "}",
          "",
          "const validateUser = ajv.compile(userSchema)",
          "const validateUsersArray = ajv.compile(userArraySchema)",
          "",
          "pm.test(`Response time is less than ${pm.environment.get(\"cfg_maxResponseTime\")} ms`, () => {",
          "    pm.expect(pm.response.responseTime).to.be.below(Number(pm.environment.get(\"cfg_maxResponseTime\")))",
          "})",
          "",
          "pm.test(`Status code is ${pm.variables.get(\"runtime_expectedStatusCode\")}`, () => {",
          "    pm.response.to.have.status(Number(pm.variables.get(\"runtime_expectedStatusCode\")))",
          "})",
          "",
          "if (userSchemaRequests.includes(pm.info.requestName)) {",
          "    pm.test(\"Response matches user schema\", () => {",
          "        pm.expect(validateUser(pm.response.json()), JSON.stringify(validateUser.errors)).to.be.true",
          "    })",
          "}",
          "",
          "if (usersArraySchemaRequests.includes(pm.info.requestName)) {",
          "    pm.test(\"Response matches array schema\", () => {",
          "        pm.expect(validateUsersArray(pm.response.json()), JSON.stringify(validateUsersArray.errors)).to.be.true",
          "    })",
          "}",
          "",
          "if (contentTypeRequests.includes(pm.info.requestName)) {",
          "    pm.test(\"Content-Type is application/json\", () => {",
          "        pm.response.to.have.header(\"Content-Type\")",
          "        pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\")",
          "    })",
          "}"
        ]
      }
    }
  ],
